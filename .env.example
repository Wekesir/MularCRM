# MySQL
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=omnicrm
MYSQL_USER=omnicrm
MYSQL_PASSWORD=omnicrm_password
MYSQL_PORT=3307

# Services
BACKEND_PORT=3000
FRONTEND_PORT=5173
PHPMYADMIN_PORT=8080

# App
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
VITE_API_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
REPORT_UNLOCK_SECRET=change-me-in-production

# Authentication
JWT_SECRET=change-me-in-production-use-long-random-string
AUTH_SESSION_TIMEZONE=Africa/Nairobi
# WebAuthn / passkeys (fingerprint, Face ID, Windows Hello)
# Defaults to hostname from FRONTEND_URL when unset
WEBAUTHN_RP_ID=
WEBAUTHN_RP_NAME=OMNICRM

# Email (Resend) — optional; can also be set in System Config → Communication Integration
RESEND_API_KEY=
RESEND_FROM=OMNICRM <onboarding@resend.dev>
# Dev only: redirect OTP emails when Resend has no verified domain yet
AUTH_DEV_OTP_EMAIL=

# Google Drive backup owner OAuth (optional; can also be set in System Config → Database Backup)
# Create an OAuth Web client in GCP and add the redirect URI shown on the Backup page.
GOOGLE_BACKUP_OAUTH_CLIENT_ID=
GOOGLE_BACKUP_OAUTH_CLIENT_SECRET=
# Public backend URL used to build the OAuth redirect (defaults to http://localhost:PORT)
BACKEND_PUBLIC_URL=http://localhost:3000
